# ============================================================
# MARKET ENTRY RADAR -- Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.

# BRIGHT DATA (required -- get yours at https://brightdata.com)
BRIGHT_DATA_API_KEY=your_bright_data_api_key_here

# BRIGHT DATA MODE
# "true" (default) = SDK mode, auto-creates zones, free tier eligible
# "false" = Legacy mode, uses custom zone names below
# BD_USE_SDK=true

# LEGACY ZONE NAMES (only needed if BD_USE_SDK=false)
# BRIGHT_DATA_SERP_ZONE=serp_api1
# BRIGHT_DATA_UNLOCKER_ZONE=web_unlocker1

# LLM PROVIDER -- choose one:
# "claude" (default) or "gemini" (free tier available)
# LLM_PROVIDER=claude

# OPTION A: Claude (Anthropic)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OPTION B: Gemini (Google AI) -- free tier, no credit card needed
# Get your key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# LLM MODEL OVERRIDE (optional -- defaults are set per provider)
# Claude default: claude-sonnet-4-20250514
# Gemini default: gemini-2.5-flash-preview-04-17
# LLM_MODEL=
